---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const productos = [
	{
		nombre: "Logitech MX Master 3S",
		categoria: "PERIFÉRICOS",
		imagen: "https://images.unsplash.com/photo-1615663245857-ac1e653815f7?auto=format&fit=crop&q=80&w=800",
		valoracionEstrellas: "⭐⭐⭐⭐⭐",
		valoracionNum: "4.7",
		descripcion: "Ratón ergonómico con sensor de 8000 DPI, scroll MagSpeed y conexión a hasta 3 dispositivos simultáneamente.",
		precio: "109€",
		enlaceAmazon: "https://amazon.es"
	},
	{
		nombre: "Sony WH-1000XM5",
		categoria: "AUDIO",
		imagen: "https://images.unsplash.com/photo-1618366712010-f4ae9c647dcb?auto=format&fit=crop&q=80&w=800",
		valoracionEstrellas: "⭐⭐⭐⭐⭐",
		valoracionNum: "4.8",
		descripcion: "Auriculares inalámbricos con la mejor cancelación de ruido del mercado y 30 horas de autonomía.",
		precio: "299€",
		enlaceAmazon: "https://amazon.es"
	},
	{
		nombre: "Teclado Keychron K2",
		categoria: "GAMING",
		imagen: "https://images.unsplash.com/photo-1595225476474-87563907a212?auto=format&fit=crop&q=80&w=800",
		valoracionEstrellas: "⭐⭐⭐⭐½",
		valoracionNum: "4.5",
		descripcion: "Teclado mecánico inalámbrico formato 75% con switches intercambiables y retroiluminación RGB.",
		precio: "95€",
		enlaceAmazon: "https://amazon.es"
	}
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-50"> 
		<Header />
		
		<main class="max-w-7xl mx-auto px-4 py-12">
			
			<h1 class="text-4xl font-extrabold mb-10 text-gray-900 border-b-4 border-orange-500 pb-2 inline-block">
				Productos Recomendados
			</h1>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					productos.map((producto) => (
						<div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 flex flex-col group">
							
							<div class="relative h-40 overflow-hidden bg-white p-6 flex items-center justify-center">
								<img 
									src={producto.imagen} 
									alt={producto.nombre} 
									class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-500"
								/>
								<span class="absolute bottom-3 left-3 bg-gray-900 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-md">
									{producto.categoria}
								</span>
							</div>
							
							<div class="p-6 flex flex-col flex-grow">
								
								<h2 class="text-gray-900 group-hover:text-orange-500 transition-colors font-bold text-lg leading-tight mb-2">
									{producto.nombre}
								</h2>
								
								<div class="flex items-center gap-2 mb-3">
									<span class="text-yellow-500 text-sm tracking-widest">{producto.valoracionEstrellas}</span>
									<span class="text-gray-600 text-sm font-medium">{producto.valoracionNum}</span>
								</div>

								<p class="text-gray-600 text-sm mb-5 flex-grow line-clamp-3 leading-relaxed">
									{producto.descripcion}
								</p>
								
								<div class="mt-auto pt-4 border-t border-gray-100 flex items-end justify-between">
									<div class="flex flex-col">
										<span class="text-[10px] text-gray-400 font-semibold tracking-wider mb-1">PRECIO REF.</span>
										<span class="text-gray-900 text-2xl font-extrabold leading-none">{producto.precio}</span>
									</div>
									
									<a 
										href={producto.enlaceAmazon} 
										target="_blank" 
										rel="nofollow noopener"
										class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-bold py-2.5 px-4 rounded-lg flex items-center gap-2 transition-colors shadow-sm"
									>
										Ver Oferta
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
									</a>
								</div>

							</div>
						</div>
					))
				}
			</div>

		</main>
		<Footer />
	</body>
</html>