---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const productos = [
	{
		nombre: "Logitech MX Master 3S",
		categoria: "PERIFÉRICOS",
		imagen: "https://m.media-amazon.com/images/I/61ni3Ky9SXL._AC_SL1500_.jpg",
		valoracion: "⭐⭐⭐⭐⭐",
		puntos: "4.8",
		descripcion: "El ratón ergonómico definitivo con scroll electromagnético y sensor de 8000 DPI. Precisión pura.",
		precio: "109,00€",
		enlace: "https://amazon.es"
	},
	{
		nombre: "Sony WH-1000XM5",
		categoria: "AUDIO",
		imagen: "https://m.media-amazon.com/images/I/51SKu69S7pL._AC_SL1500_.jpg",
		valoracion: "⭐⭐⭐⭐⭐",
		puntos: "4.9",
		descripcion: "Líder en cancelación de ruido activa con 30 horas de batería y llamadas ultra nítidas.",
		precio: "299,00€",
		enlace: "https://amazon.es"
	},
	{
		nombre: "Keychron K2 V2",
		categoria: "TECLADOS",
		imagen: "https://m.media-amazon.com/images/I/71Yv-p6vFPL._AC_SL1500_.jpg",
		valoracion: "⭐⭐⭐⭐½",
		puntos: "4.6",
		descripcion: "Teclado mecánico inalámbrico 75% con retroiluminación RGB y compatible con Mac/Windows.",
		precio: "99,00€",
		enlace: "https://amazon.es"
	}
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[#f8f9fa]">
		<Header />
		<main class="max-w-7xl mx-auto px-4 py-16">
			
			<h1 class="text-3xl font-black text-gray-900 mb-12 uppercase tracking-tight border-l-8 border-orange-500 pl-4">
				Productos <span class="text-orange-500">Destacados</span>
			</h1>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
				{productos.map((item) => (
					<div class="group bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-2xl transition-all duration-300 hover:-translate-y-3 flex flex-col overflow-hidden">
						
						<div class="relative h-56 bg-white p-8 flex items-center justify-center overflow-hidden">
							<img src={item.imagen} alt={item.nombre} class="max-w-full max-h-full object-contain transition-transform duration-500 group-hover:scale-110" />
							<span class="absolute top-4 left-4 bg-black text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest shadow-lg">
								{item.categoria}
							</span>
						</div>

						<div class="p-6 flex flex-col flex-grow bg-white">
							<h2 class="text-xl font-bold text-gray-900 group-hover:text-orange-500 transition-colors duration-300 mb-2">
								{item.nombre}
							</h2>
							
							<div class="flex items-center gap-2 mb-4">
								<span class="text-yellow-400 text-sm">{item.valoracion}</span>
								<span class="text-gray-400 text-xs font-bold">({item.puntos})</span>
							</div>

							<p class="text-gray-500 text-sm leading-relaxed mb-6 flex-grow line-clamp-3">
								{item.descripcion}
							</p>

							<div class="pt-5 border-t border-gray-100 flex items-center justify-between">
								<div class="flex flex-col">
									<span class="text-[9px] text-gray-400 font-black uppercase tracking-tighter">Precio Ref.</span>
									<span class="text-2xl font-black text-gray-900 leading-none">{item.precio}</span>
								</div>
								
								<a href={item.enlace} target="_blank" rel="nofollow" class="bg-orange-500 hover:bg-black text-white text-[11px] font-bold py-3 px-6 rounded-xl transition-all duration-300 shadow-lg shadow-orange-200 hover:shadow-none uppercase tracking-wider">
									Ver Oferta
								</a>
							</div>
						</div>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>