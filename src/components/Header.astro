---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<img src="/logo.png" alt="Logo de Sales DMH" class="site-logo" />
		</a>
		
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/ofertas">Ofertas 🔥</HeaderLink>
			<HeaderLink href="/blog">Guías de Compra</HeaderLink>
			<HeaderLink href="/tecnologia">Tecnología</HeaderLink>
			<HeaderLink href="/about">Sobre nosotros</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	
	/* Estilos para que el logo se vea perfecto Y GRANDE */
	.logo-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		padding: 0.5em 0; /* Un poco de aire arriba y abajo */
	}
	.site-logo {
		height: 80px; /* Tamaño grande en escritorio */
		width: auto;
		display: block;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 500;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: #f97316; /* Naranja para la pestaña activa */
	}
	.internal-links {
		display: flex;
		gap: 1.5rem;
	}
	
	@media (max-width: 720px) {
		.internal-links {
			gap: 0.5rem;
			font-size: 0.85em; /* Un poco más pequeño para que quepa todo */
			flex-wrap: wrap; /* Si no caben en una línea, bajan a la siguiente de forma limpia */
			justify-content: center;
			padding-bottom: 1em; /* Espacio extra abajo en móvil */
		}
		/* Hacemos el logo un poco más pequeño en móviles */
		.site-logo {
			height: 55px; 
		}
		nav {
			flex-direction: column; /* En móvil, el logo va arriba y el menú debajo */
		}
	}
</style>